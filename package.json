{
  "name": "naviga-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx apps/worker/index.ts",
    "dev:web": "tsx apps/web/index.ts",
    "tunnel": "cloudflared --config ./cloudflare/config.yml tunnel run naviga-tunnel",
    "dev:public": "concurrently -k -n web,tunnel -c blue,green \"npm run dev:web\" \"npm run tunnel\"",
    "test": "node --import tsx --test",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "express": "^5.1.0",
    "playwright": "^1.58.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
